# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-min-32-characters-here

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-min-32-characters-here
JWT_ACCESS_TOKEN_EXPIRES_DAYS=7

# Database
# Development: SQLite (no setup required)
DATABASE_URL=sqlite:///app.db
# Production: switch to PostgreSQL by changing the above to:
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Google Books API (fallback for metadata / cover images)
GOOGLE_BOOKS_API_KEY=your-google-books-api-key-here

# CORS (comma-separated allowed origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
